<style>
    .error-box {
  background-color: #ffe5e5;
  border: 1px solid #ff4d4d;
  color: #b30000;
  padding: 12px 15px;
  border-radius: 8px;
  margin-bottom: 15px;
  font-size: 14px;
}

.error-box ul {
  list-style: none;
  padding-left: 0;
}

.error-box li {
  margin-bottom: 5px;
}

</style>

<% if (errors && errors.length > 0) { %>
  <div class="error-box">
    <ul>
      <% errors.forEach(err => { %>
        <li>⚠ <%= err %></li>
      <% }) %>
    </ul>
  </div>
<% } %>
